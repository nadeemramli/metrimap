# metrimap-mcp-server — copy to .env (git-ignored) and fill in.
# Server-only secrets — NEVER ship to the browser bundle.

SUPABASE_URL=https://iqrclwolhookzzmiedun.supabase.co
SUPABASE_ANON_KEY=<your Supabase anon/publishable key>

# The signer for per-user RLS tokens. Supabase dashboard →
# Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=<your Supabase JWT secret>

# Clerk = the OAuth authorization server for the "Connect with sign-in" flow.
# Secret key (server-only) verifies incoming OAuth access tokens; publishable
# key identifies the Clerk instance in the resource metadata. Enable Dynamic
# Client Registration in the Clerk Dashboard (OAuth applications).
CLERK_SECRET_KEY=<your Clerk secret key: sk_live_… / sk_test_…>
CLERK_PUBLISHABLE_KEY=<your Clerk publishable key: pk_live_…>

# Public origin of this server (used to build the OAuth resource id + metadata).
MCP_PUBLIC_URL=https://mcp.canvasm.app

PORT=8787
